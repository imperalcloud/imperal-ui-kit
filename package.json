{
  "name": "@imperal/ui-kit",
  "version": "0.1.0",
  "description": "Imperal declarative UI renderer — shared React component library.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup && npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --content './src/**/*.{ts,tsx}'",
    "build:css": "npx @tailwindcss/cli -i src/styles.css -o dist/styles.css --content './src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "peerDependenciesMeta": {
    "@tiptap/react": { "optional": true },
    "@tiptap/starter-kit": { "optional": true },
    "@tiptap/extension-placeholder": { "optional": true },
    "cytoscape": { "optional": true },
    "cytoscape-cose-bilkent": { "optional": true },
    "react-cytoscapejs": { "optional": true },
    "recharts": { "optional": true },
    "react-markdown": { "optional": true },
    "remark-gfm": { "optional": true },
    "react-syntax-highlighter": { "optional": true },
    "dompurify": { "optional": true }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@tailwindcss/typography": "^0.5",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "cytoscape": "^3.33.2",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.468.0",
    "react": "19.1.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.13.3",
    "remark-gfm": "^4.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4",
    "tsup": "^8",
    "typescript": "^5"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imperalcloud/imperal-ui-kit.git"
  },
  "license": "UNLICENSED"
}
